# ─── Required ────────────────────────────────────────────────────────────────────

# Token for the admin panel (choose something long and random)
ADMIN_TOKEN=change-me-to-something-secret

# Your droplet's public URL (no trailing slash)
PUBLIC_URL=https://yourdomain.com

# ─── Optional ────────────────────────────────────────────────────────────────────

# Voter token — auto-generated on startup if left blank (recommended)
# Set this only if you need a stable, predictable token.
VOTER_TOKEN=

# SSL certificate paths (from Let's Encrypt / certbot)
# When set, the server runs HTTPS on port 443.
# Without these, the server runs plain HTTP on port 80.
SSL_KEY=/etc/letsencrypt/live/yourdomain.com/privkey.pem
SSL_CERT=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
